        <mxCell id="36OamRU7qbAxRdqJdja1-181" value="&lt;div style=&quot;text-align: left;&quot;&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;&lt;b&gt;Read:&lt;/b&gt;&lt;/span&gt;&lt;/div&gt;&lt;div style=&quot;text-align: left;&quot;&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;0x00(Request of read)&lt;/span&gt;&lt;/div&gt;&lt;div style=&quot;text-align: left;&quot;&gt;0xFF(Response of read)&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div style=&quot;text-align: left;&quot;&gt;&lt;b&gt;Write:&lt;/b&gt;&lt;/div&gt;&lt;div style=&quot;text-align: left;&quot;&gt;0x55(Request of write)&lt;/div&gt;&lt;div style=&quot;text-align: left;&quot;&gt;0xAA(Response of writte)&lt;/div&gt;&lt;div style=&quot;text-align: left;&quot;&gt;&lt;br&gt;&lt;/div&gt;&lt;div style=&quot;text-align: left;&quot;&gt;&lt;b&gt;Exception:&lt;/b&gt;&lt;/div&gt;&lt;div style=&quot;text-align: left;&quot;&gt;0x11(Read fail)&lt;/div&gt;&lt;div style=&quot;text-align: left;&quot;&gt;0x22(Write fail)&lt;/div&gt;" style="shape=partialRectangle;html=1;whiteSpace=wrap;connectable=0;strokeColor=inherit;overflow=hidden;fillColor=none;top=0;left=0;bottom=0;right=0;pointerEvents=1;fontSize=16;" parent="36OamRU7qbAxRdqJdja1-177" vertex="1">
          <mxGeometry x="100" width="204" height="291" as="geometry">
            <mxRectangle width="204" height="291" as="alternateBounds" />
          </mxGeometry>
        </mxCell>
        <mxCell id="36OamRU7qbAxRdqJdja1-182" value="&lt;div style=&quot;&quot;&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;0: U8&lt;/span&gt;&lt;/div&gt;&lt;div style=&quot;&quot;&gt;1: S8&lt;/div&gt;&lt;div style=&quot;&quot;&gt;2: U16&lt;/div&gt;&lt;div style=&quot;&quot;&gt;3: S16&lt;/div&gt;&lt;div style=&quot;&quot;&gt;4: U32&lt;/div&gt;&lt;div style=&quot;&quot;&gt;5: S32&lt;/div&gt;&lt;div style=&quot;&quot;&gt;6: Float32&lt;/div&gt;" style="shape=partialRectangle;html=1;whiteSpace=wrap;connectable=0;strokeColor=inherit;overflow=hidden;fillColor=none;top=0;left=0;bottom=0;right=0;pointerEvents=1;fontSize=16;align=left;" parent="36OamRU7qbAxRdqJdja1-177" vertex="1">
          <mxGeometry x="304" width="205" height="291" as="geometry">
