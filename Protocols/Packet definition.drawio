        <mxCell id="36OamRU7qbAxRdqJdja1-184" value="Low byte&lt;div&gt;(Network order)&lt;/div&gt;" style="shape=partialRectangle;html=1;whiteSpace=wrap;connectable=0;strokeColor=inherit;overflow=hidden;fillColor=none;top=0;left=0;bottom=0;right=0;pointerEvents=1;fontSize=16;" parent="36OamRU7qbAxRdqJdja1-177" vertex="1">
